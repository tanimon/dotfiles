{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "HOME": "{{ .chezmoi.homeDir }}",
    "LANG": "ja_JP.UTF-8",
    {{/* _ZO_DOCTOR: Shell snapshot preserves zoxide cd function but not zsh chpwd_functions array, causing false-positive doctor warnings. */ -}}
    "_ZO_DOCTOR": "0"
  },
  "permissions": {
    "allow": [
      "Bash(colima list:*)",
      "Bash(cp:*)",
      "Bash(docker compose:*)",
      "Bash(docker exec:*)",
      "Bash(docker inspect:*)",
      "Bash(docker logs:*)",
      "Bash(docker ps:*)",
      "Bash(fd:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr reviews:*)",
      "Bash(gh pr view:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(git submodule:*)",
      "Bash(git worktree:*)",
      "Bash(go build:*)",
      "Bash(go doc:*)",
      "Bash(go env:*)",
      "Bash(go generate:*)",
      "Bash(go get:*)",
      "Bash(go list:*)",
      "Bash(go mod:*)",
      "Bash(go test:*)",
      "Bash(go tool cover:*)",
      "Bash(go vet:*)",
      "Bash(gofmt:*)",
      "Bash(golangci-lint run:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(make:*)",
      "Bash(mise:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(python3:*)",
      "Bash(realpath:*)",
      "Bash(time go test:*)",
      "Bash(tree:*)",
      "Bash(vite:*)",
      "Bash(wc:*)",
      "Edit(!.git/**)",
      "Edit(!build/**)",
      "Edit(!dist/**)",
      "Edit(!node_modules/**)",
      "Edit(!vendor/**)",
      "mcp__context7",
      "mcp__deepwiki",
      "Read({{ .chezmoi.homeDir }}/ghq/github.com/{{ .ghOrg }}/**)",
      "WebFetch(domain:*)",
      "WebSearch",
      "Write(!.git/**)",
      "Write(!build/**)",
      "Write(!dist/**)",
      "Write(!node_modules/**)",
      "Write(!vendor/**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(sudo:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(> /dev/*)",
      "Bash(>> /dev/*)",
      "Bash(chmod 777:*)",
      "Bash(chown root:*)",
      "Bash(sudo chmod 777:*)",
      "Bash(sudo chown:*)",
      "Bash(sudo -i:*)",
      "Bash(sudo su:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm -rf .git)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(docker system prune -af)",
      "Bash(npm publish:*)",
      "Bash(cargo publish:*)",
      "Bash(deno publish:*)",
      "Edit(/etc/**)",
      "Edit(/usr/**)",
      "Edit(/var/**)",
      "Edit(/opt/**)",
      "Edit(/bin/**)",
      "Edit(/sbin/**)",
      "Edit(/lib/**)",
      "Edit(/lib64/**)",
      "Edit(/boot/**)",
      "Edit(/proc/**)",
      "Edit(/sys/**)",
      "Edit(/dev/**)",
      "Edit(~/.ssh/id_*)",
      "Edit(~/.ssh/*_rsa)",
      "Edit(~/.ssh/*_ecdsa)",
      "Edit(~/.ssh/*_ed25519)",
      "Edit(/etc/passwd)",
      "Edit(/etc/shadow)",
      "Edit(/etc/sudoers)",
      "Write(/etc/**)",
      "Write(/usr/**)",
      "Write(/var/**)",
      "Write(/opt/**)",
      "Write(/bin/**)",
      "Write(/sbin/**)",
      "Write(/lib/**)",
      "Write(/lib64/**)",
      "Write(/boot/**)",
      "Write(/proc/**)",
      "Write(/sys/**)",
      "Write(/dev/**)",
      "Write(~/.ssh/*_rsa)",
      "Write(~/.ssh/*_ecdsa)",
      "Write(~/.ssh/*_ed25519)",
      "Write(/etc/passwd)",
      "Write(/etc/shadow)",
      "Write(/etc/sudoers)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "{{ .chezmoi.homeDir }}/ghq/github.com/{{ .ghOrg }}/**"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'command -v jq >/dev/null || { echo \"jq not found\" >&2; exit 1; }; SID=$(jq -r \".session_id // empty\"); [ -n \"$SID\" ] && rm -f \"/tmp/claude-harness-checked-$SID\" || true'"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'find /tmp -maxdepth 1 -name \"claude-harness-checked-*\" -mtime +0 -delete 2>/dev/null; find /tmp -maxdepth 1 -name \"claude-harness-feedback-*\" -mtime +0 -delete 2>/dev/null; true'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'mkdir -p \"$HOME/.claude/logs\" && \"$HOME/.claude/scripts/notify-wrapper.sh\" 2>>\"$HOME/.claude/logs/notify-errors.log\" || true'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=\"$CLAUDE_FILE\"; case \"$FILE\" in *.ts|*.tsx) pnpm lint:fix \"$FILE\" ;; *.go) gofmt -w \"$FILE\" ;; esac'"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=\"$CLAUDE_FILE\"; case \"$FILE\" in *.env|*.env.*|*credentials*|*secret*) if command -v secretlint >/dev/null 2>&1; then OUTPUT=$(secretlint \"$FILE\" 2>&1) || { echo \"secretlint: potential secret detected in $FILE: $OUTPUT\" >&2; exit 1; }; fi ;; esac'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'mkdir -p \"$HOME/.claude/logs\" && \"$HOME/.claude/scripts/notify-wrapper.sh\" 2>>\"$HOME/.claude/logs/notify-errors.log\" || true'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '\"$HOME/.claude/scripts/harness-feedback-collector.sh\" 2>>\"$HOME/.claude/logs/harness-errors.log\" || true'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/skills/claudeception/scripts/claudeception-activator.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '\"$HOME/.claude/scripts/harness-check.sh\" 2>>\"$HOME/.claude/logs/harness-errors.log\" || true'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node --experimental-strip-types $HOME/.claude/statusline-command.ts"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": false,
    "planning-with-files@planning-with-files": false,
    "gopls-lsp@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": false,
    "everything-claude-code@everything-claude-code": false,
    "commit-commands@claude-plugins-official": true,
    "claude-delegator@jarrodwatts-claude-delegator": false,
    "compound-engineering@compound-engineering-plugin": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      },
      "autoUpdate": true
    },
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      },
      "autoUpdate": true
    },
    "jarrodwatts-claude-delegator": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-delegator"
      }
    },
    "planning-with-files": {
      "source": {
        "source": "github",
        "repo": "OthmanAdi/planning-with-files"
      }
    },
    "agent-plugins-for-aws": {
      "source": {
        "source": "github",
        "repo": "awslabs/agent-plugins"
      }
    }
  },
  "language": "japanese",
  "sandbox": {
    "enabled": false
  },
  "skipDangerousModePermissionPrompt": true
}
