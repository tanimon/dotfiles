{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail

SOURCE_DIR="{{ .chezmoi.sourceDir }}"
HOME_DIR="{{ .chezmoi.homeDir }}"
PLUGINS_SRC="${SOURCE_DIR}/dot_claude/plugins"
TMPL_VAR='{{ "{{ .chezmoi.homeDir }}" }}'

sync_plugin_file() {
  local name="$1"
  local src="${HOME_DIR}/.claude/plugins/${name}"
  local dest="${PLUGINS_SRC}/.${name}.data"

  if [ -f "$src" ]; then
    cp "$src" "$dest"
    sed -i '' "s|${HOME_DIR}|${TMPL_VAR}|g" "$dest"
  fi
}

sync_plugin_file "installed_plugins.json"
sync_plugin_file "known_marketplaces.json"
{{ end -}}
