{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail

MARKETPLACES_FILE="{{ .chezmoi.homeDir }}/.claude/plugins/known_marketplaces.json"

if [ ! -f "$MARKETPLACES_FILE" ]; then
  exit 0
fi

if ! command -v claude &>/dev/null || ! command -v jq &>/dev/null; then
  exit 0
fi

jq -r 'to_entries[] | "\(.value.installLocation)\t\(.value.source.repo // .value.source.url)"' "$MARKETPLACES_FILE" | while IFS=$'\t' read -r install_location source_value; do
  if [ -d "$install_location" ]; then
    continue
  fi
  echo "Adding missing marketplace: ${source_value}"
  claude plugin marketplace add "$source_value" || true
done
{{ end -}}
