#!/usr/bin/env bash
# package.json hash: {{ include "package.json" | sha256sum }}
# .pre-commit-config.yaml hash: {{ include ".pre-commit-config.yaml" | sha256sum }}

set -euo pipefail

# mise ツールが未インストールの場合はスキップ（新マシン初回 apply 時）
command -v pnpm >/dev/null 2>&1 || { echo "pnpm not found, skipping secretlint setup (run 'mise install' first)"; exit 0; }

cd {{ .chezmoi.sourceDir | quote }}

echo "Installing secretlint dependencies..."
pnpm install --frozen-lockfile 2>/dev/null || pnpm install

echo "Installing pre-commit hooks..."
command -v prek >/dev/null 2>&1 && prek install || echo "prek not found, skipping hook install (run 'mise install' first)"
