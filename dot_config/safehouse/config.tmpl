# safehouse configuration for Claude Code sandbox
# Each line is a CLI argument passed to safehouse
# Lines starting with # are comments
#
# Architecture:
#   safehouse assembles a deny-all Seatbelt profile from 40+ built-in .sb files.
#   CLI flags here are processed in Phase 4 (after all built-in profiles).
#   --add-dirs / --add-dirs-ro auto-detect file vs directory and emit the
#   correct Seatbelt rule type (literal for files, subpath for directories).
#   Ancestor literal rules are also auto-generated — no manual setup needed.
#
# Already covered by safehouse built-in profiles (do NOT add here):
#   claude-code.sb:       ~/.claude (rw), ~/.claude.json (rw), ~/.local/share/claude
#   keychain.sb:          ~/Library/Keychains (auto-required by claude-code)
#   git.sb:               ~/.gitconfig, ~/.gitignore, ~/.config/git, ~/.ssh/config
#   scm-clis.sb:          ~/.config/gh (rw)
#   runtime-managers.sb:  ~/.local/share/mise, ~/.config/mise (rw)
#   node.sb:              ~/.npm, ~/.npmrc, ~/.node_repl_history
#   rust.sb:              ~/.cargo, ~/.rustup
#   go.sb:                ~/go, ~/.cache/go-build
#   python.sb:            ~/.python_history

# --- Integrations (opt-in modules) ---
--enable=ssh
--enable=1password
--enable=docker
--enable=shell-init
--enable=clipboard
--enable=process-control
--enable=playwright-chrome

# --- Working directories (read-write) ---
--add-dirs={{ .chezmoi.homeDir }}/ghq
--add-dirs={{ .chezmoi.homeDir }}/.cache
--add-dirs={{ .chezmoi.homeDir }}/.codex
--add-dirs={{ .chezmoi.homeDir }}/.gstack

# --- Binaries and tools (read-only) ---
# ~/.local/bin has claude symlink (covered by claude-code.sb as literal)
# but also other user-installed binaries that need PATH resolution
--add-dirs-ro={{ .chezmoi.homeDir }}/.local/bin
--add-dirs-ro={{ .chezmoi.homeDir }}/.local/share/cco

# --- chezmoi (read-only) ---
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/chezmoi
--add-dirs-ro={{ .chezmoi.homeDir }}/.local/share/chezmoi

# --- Dotfiles in $HOME root (read-only, for chezmoi diff/comparison) ---
# shell-init covers: ~/.zshrc, ~/.zprofile, ~/.zshenv
--add-dirs-ro={{ .chezmoi.homeDir }}/.bashrc
--add-dirs-ro={{ .chezmoi.homeDir }}/.bash_profile
--add-dirs-ro={{ .chezmoi.homeDir }}/.vimrc
--add-dirs-ro={{ .chezmoi.homeDir }}/.tmux.conf
--add-dirs-ro={{ .chezmoi.homeDir }}/.cVimrc

# --- Dev tool state (read-only) ---
--add-dirs-ro={{ .chezmoi.homeDir }}/.bun
--add-dirs-ro={{ .chezmoi.homeDir }}/.pnpm-state
--add-dirs-ro={{ .chezmoi.homeDir }}/.agents

# --- ~/.config subdirectories (read-only, not covered by built-in profiles) ---
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/cco
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/safehouse
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/ghostty
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/helix
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/karabiner
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/opencode
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/sheldon
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/starship.toml
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/yazi
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/zed
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/zellij
--add-dirs-ro={{ .chezmoi.homeDir }}/.config/zsh
