# Paths to allow read-write access in cco sandbox (one per line)
# These are passed as --add-dir arguments to cco
# Append :ro for read-only access (default is :rw)
{{ .chezmoi.homeDir }}/ghq
# Allow sandbox to read/execute the claude binary
{{ .chezmoi.homeDir }}/.local/bin:ro
{{ .chezmoi.homeDir }}/.local/share/claude:ro
# Git config files (needed for commit signing, global ignore, aliases)
{{ .chezmoi.homeDir }}/.gitconfig:ro
{{ .chezmoi.homeDir }}/.config/git:ro
# mise-managed tools (prek for pre-commit hooks, etc.)
{{ .chezmoi.homeDir }}/.local/share/mise:ro
# 1Password SSH agent socket (for git commit signing)
{{ .chezmoi.homeDir }}/Library/Group Containers/2BUA8C4S2C.com.1password:ro
